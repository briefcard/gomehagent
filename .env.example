# --- Claude API (console.anthropic.com -> API keys) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Google OAuth app (Cloud Console -> Credentials -> Desktop client) ---
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# --- Inboxes (refresh tokens from scripts/google_oauth.py) ---
GMAIL_ACCOUNTS_JSON={"personal":{"email":"gomehsaias@gmail.com","refresh_token":"..."},"baci":{"email":"gs@bacimilanousa.com","refresh_token":"..."},"eien":{"email":"store@eienhealth.com","refresh_token":"..."}}

APPROVER_EMAIL=gomehsaias@gmail.com
NOTIFY_FROM_ALIAS=personal
PUBLIC_BASE_URL=https://assistant-web.onrender.com
APPROVAL_SECRET=change-me-long-random
POLL_INTERVAL_MIN=5

# --- SEO agent (role: seo) — Semrush Analytics API ---
# Semrush -> Profile -> Subscription info -> API (Analytics units required).
SEMRUSH_API_KEY=
SEO_DOMAIN=bacimilanousa.com
SEO_DATABASE=us
# Compliance: keyword substrings the opportunity finder must never recommend.
# Baci is Italian-DESIGNED, not made in Italy — origin claims are off-limits.
SEO_EXCLUDE_TERMS=made in italy,from italy,italian made,made italy,imported from italy
# Optional: set to claude-opus-4-8 for heavier SEO analysis (defaults to CLAUDE_MODEL)
SEO_MODEL=
# Multi-site / multi-platform. Primary site = the SEO_* vars above; SEO_PLATFORM
# picks its backend (shopify|wordpress). Add more clients via SEO_SITES_JSON.
SEO_PLATFORM=shopify
SEO_PRIMARY_SITE=baci
SEO_SITES_JSON={"eien":{"domain":"eienhealth.com","database":"us","platform":"shopify","creds_key":"eien"},"mtw":{"domain":"marketingthatworks.co","database":"us","platform":"wordpress","creds_key":"mtw","voice":"Confident plain-English B2B marketing voice."}}
# WordPress creds per creds_key (WP Application Passwords — user profile screen):
WORDPRESS_SITES_JSON={"mtw":{"base_url":"https://marketingthatworks.co","user":"editor","app_password":"xxxx xxxx xxxx xxxx xxxx xxxx"}}
# GSC + GA4 (real ranking/click + traffic/conversion truth). Re-run
# scripts/google_oauth.py to grant webmasters.readonly + analytics.readonly, then
# update GMAIL_ACCOUNTS_JSON. SEO_GOOGLE_ALIAS = the ONE account you grant into
# each property (default personal). Leave the property vars BLANK — the agent
# auto-discovers the GSC site + GA4 property by domain and saves them in the DB.
SEO_GOOGLE_ALIAS=personal
SEO_GSC_SITE=
SEO_GA4_PROPERTY=

# --- WhatsApp Cloud API (leave blank until Meta verification done) ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_APPROVER_NUMBER=
WHATSAPP_VERIFY_TOKEN=pick-any-string

# Local dev only (Render injects real Postgres)
DATABASE_URL=sqlite:///local.db
