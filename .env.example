# --- Claude API (console.anthropic.com -> API keys) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Google OAuth app (Cloud Console -> Credentials -> Desktop client) ---
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# --- Inboxes (refresh tokens from scripts/google_oauth.py) ---
GMAIL_ACCOUNTS_JSON={"personal":{"email":"gomehsaias@gmail.com","refresh_token":"..."},"baci":{"email":"gs@bacimilanousa.com","refresh_token":"..."},"eien":{"email":"store@eienhealth.com","refresh_token":"..."}}

APPROVER_EMAIL=gomehsaias@gmail.com
NOTIFY_FROM_ALIAS=personal
PUBLIC_BASE_URL=https://assistant-web.onrender.com
APPROVAL_SECRET=change-me-long-random
POLL_INTERVAL_MIN=5

# ============ SEO AGENT (role: seo) — multi-client, multi-platform ============
# Semrush -> Profile -> Subscription info -> API (Analytics units required).
SEMRUSH_API_KEY=
# ONE Google account granted into EVERY client's Search Console + GA4 property
# (default personal). Re-run scripts/google_oauth.py to grant webmasters.readonly
# + analytics.readonly, then update GMAIL_ACCOUNTS_JSON.
SEO_GOOGLE_ALIAS=personal
# Which site key in SEO_SITES_JSON is the default when no site is named.
SEO_PRIMARY_SITE=baci
# Loop model. Blank = Opus (default). Set claude-sonnet-4-6 to cut cost.
SEO_MODEL=
#
# RECOMMENDED: define EVERY client here (the primary included) — one uniform
# structure; adding a client is just one more object + its creds below. Per
# client: domain, database (Semrush market), platform (shopify|wordpress),
# creds_key (a key in SHOPIFY_STORES_JSON / WORDPRESS_SITES_JSON), optional
# exclude_terms[] (keywords the opportunity finder won't target), guardrail
# (copy/compliance rule obeyed strictly), voice. GSC/GA4 properties auto-discover
# by domain — don't set them. IMPORTANT: inside the JSON write guardrail/voice
# WITHOUT double quotes (parens/single quotes are fine) or the JSON breaks; a
# broken value drops all sites, so validate edits.
SEO_SITES_JSON={"baci":{"domain":"bacimilanousa.com","database":"us","platform":"shopify","creds_key":"baci","exclude_terms":["made in italy","from italy","italian made","made italy","imported from italy","handmade","hand-made","hand made","handcrafted","hand-crafted","hand crafted","craftsmanship","artisan","artisanal","hand-painted","handpainted","hand painted"],"guardrail":"Italian-DESIGNED brand (Milan), mass-manufactured: NOT made in Italy, NOT handmade, NOT artisanal. Pursue Italian-product style and design terms, but never claim or imply Italian manufacture (made in Italy, from Italy, Italian-made), handcraft (handmade, hand-crafted, hand-painted, artisan), or craftsmanship. Position as Italian design / designed in Milan. If existing copy makes any such claim, flag it for correction.","voice":"Premium, design-led, playful Italian-style tableware voice."},"eien":{"domain":"eienhealth.com","database":"us","platform":"shopify","creds_key":"eien","exclude_terms":["cure","treats disease","prevents disease","fda approved"],"guardrail":"Health and wellness brand: NO medical claims. Never say a product cures, treats, prevents, or diagnoses any disease. Use compliant wellness language (supports, helps maintain). No FDA-approved claims. Keep every claim substantiated and FTC-compliant.","voice":"Warm, credible, science-aware wellness voice."},"mtw":{"domain":"marketingthatworks.co","database":"us","platform":"wordpress","creds_key":"mtw","guardrail":"B2B services: no inflated guarantees or unverifiable ROI claims; use case studies and specifics, not hype.","voice":"Confident, plain-English B2B marketing voice."}}
# Shopify creds per store key (shared with the admin agent):
SHOPIFY_STORES_JSON={"baci":{"domain":"YOUR-BACI.myshopify.com","token":"shpat_..."},"eien":{"domain":"YOUR-EIEN.myshopify.com","token":"shpat_..."}}
# WordPress creds per creds_key (WP Application Passwords — user profile screen):
WORDPRESS_SITES_JSON={"mtw":{"base_url":"https://marketingthatworks.co","user":"editor","app_password":"xxxx xxxx xxxx xxxx xxxx xxxx"}}
#
# OPTIONAL single-site fallback for the primary — used ONLY if SEO_PRIMARY_SITE is
# absent from SEO_SITES_JSON. Keeping SEO_DOMAIN + SEO_STORE set is a safety net so
# a SEO_SITES_JSON typo can't take the primary down. The rest are ignored once the
# primary is defined in SEO_SITES_JSON above.
SEO_DOMAIN=bacimilanousa.com
SEO_STORE=baci
SEO_PLATFORM=shopify
SEO_DATABASE=us
SEO_GSC_SITE=
SEO_GA4_PROPERTY=
SEO_VOICE=
SEO_GUARDRAIL=
SEO_EXCLUDE_TERMS=

# --- WhatsApp Cloud API (leave blank until Meta verification done) ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_APPROVER_NUMBER=
WHATSAPP_VERIFY_TOKEN=pick-any-string

# Local dev only (Render injects real Postgres)
DATABASE_URL=sqlite:///local.db
